{
    "latex-workshop.latex.outDir": "./build",
    "latex-workshop.latex.tools": [
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-output-directory=build",
                "%DOC%"
            ]
        },
        {
            "name": "pdflatex-escaped",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-shell-escape",
                "-output-directory=build",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "build/%DOCFILE%"
            ]
        },
        {
            "name": "bibtex-pub",
            "command": "bibtex",
            "args": ["build/pub.aux"]
        },
        {
           "name": "biber",
            "command": "biber",
            "args": ["--input-directory=build", "--output-directory=build", "%DOCFILE%"]
        },
        {
            "name": "bibtexmy",
            "command": "bibtex",
            "args": [
            "build/my",
            "-terse"
            ],
            "env": {}
        },
        {
            "name": "bibtexgeneral",
            "command": "bibtex",
            "args": [
            "build/general",
            "-terse"
            ],
            "env": {}
        }
    ],

        "latex-workshop.latex.recipes": [
            {
                "name": "heavy",
                "tools": ["pdflatex", "bibtex", "pdflatex", "pdflatex"]
            },
            {
                "name": "lightweight",
                "tools": ["pdflatex"]
            },
            {
                "name": "irt-thesis",
                "tools": ["pdflatex-escaped", "bibtex", "pdflatex-escaped", "pdflatex-escaped"]
            },
            {
                "name": "irt-thesis-phd",
                "tools": [
                "pdflatex",
                "bibtexgeneral",
                "bibtexmy",
                "pdflatex",
                "pdflatex"
                ]
            }
    ],
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.latex.recipe.default": "irt-thesis"
}