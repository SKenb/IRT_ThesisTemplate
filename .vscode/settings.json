{
    "latex-workshop.latex.outDir": "./build",
    "latex-workshop.latex.tools": [
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-output-directory=build",
                "%DOC%"
            ]
        },
        {
            "name": "pdflatex-escaped",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-shell-escape",
                "-output-directory=build",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "build/%DOCFILE%"
            ]
        },
        {
            "name": "bibtex-pub",
            "command": "bibtex",
            "args": ["build/pub.aux"]
        },
        {
           "name": "biber",
            "command": "biber",
            "args": ["--input-directory=build", "--output-directory=build", "%DOCFILE%"]
        }
    ],

        "latex-workshop.latex.recipes": [
            {
                "name": "heavy",
                "tools": ["pdflatex", "bibtex", "pdflatex", "pdflatex"]
            },
            {
                "name": "lightweight",
                "tools": ["pdflatex"]
            },
            {
                "name": "heavy with shell escape",
                "tools": ["pdflatex-escaped", "bibtex", "pdflatex-escaped", "pdflatex-escaped"]
            }
    ],
    "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.recipe.default": "heavy with shell escape"
}